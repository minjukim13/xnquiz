    <mxCell id="e3" value="학생" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;" edge="1" source="role" target="ql_s" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- 교수자 내부: ql_i → 2열 (수평, 같은 Y 없음) -->
    <mxCell id="e4" value="새 퀴즈"  style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ql_i" target="qc"  parent="lane_i"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e5" value="편집"     style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ql_i" target="qe"  parent="lane_i"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e6" value="채점하기" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ql_i" target="gd"  parent="lane_i"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e7" value="문제은행" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ql_i" target="qbl" parent="lane_i"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- 2열 → 3열 -->
    <mxCell id="e8" value="통계 보기" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="gd"  target="qs" parent="lane_i"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="e9" value="은행 선택" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="qbl" target="qb" parent="lane_i"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- 학생 내부 -->
    <mxCell id="e10" value="응시하기" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=12;fontFamily=Pretendard,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ql_s" target="qa" parent="lane_s"><mxGeometry relative="1" as="geometry" /></mxCell>

  </root>
</mxGraphModel>
