# .env.example — 팀 공유용 키 목록 (실제 값 없음)
# 복사 후 .env.local 로 저장하고 값 입력

# ─────────────────────────────────────────────
# Frontend (Vite)
# ─────────────────────────────────────────────
VITE_DATA_SOURCE=mock
VITE_APP_NAME=XN Quizzes

# Canvas OAuth (Canvas Admin > Developer Keys 에서 발급)
VITE_CANVAS_BASE_URL=
VITE_CANVAS_CLIENT_ID=
VITE_CANVAS_REDIRECT_URI=

# Canvas Client Secret — VITE_ 없이 등록 (서버사이드 전용)
CANVAS_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Backend (Vercel Serverless Functions)
# ─────────────────────────────────────────────

# Supabase PostgreSQL — Supabase Dashboard > Project Settings > Database 에서 복사
# 형식: postgresql://postgres.<project>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 마이그레이션용 직접 연결 URL (pooler 미경유, 5432 포트)
# Supabase Dashboard 의 "Connection string > URI" 값 (pooler 아님) 사용
DIRECT_URL=postgresql://postgres.<project>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# JWT — 운영 환경에서는 `openssl rand -base64 32` 같은 방식으로 생성
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# LTI 1.3 (Canvas 연동)
# ─────────────────────────────────────────────

# xnquiz 외부 공개 URL (Canvas 가 LTI launch 시 redirect 받을 도메인)
# 예: https://xnquiz.vercel.app
XNQUIZ_PUBLIC_URL=

# [시연 전용] Canvas Personal Access Token
# - 발급: Canvas > 계정 > 프로필 > 설정 > 하단 "새 액세스 토큰"
# - 용도: 시드 스크립트에서 Canvas "과제 및 평가" 에 external_tool Assignment 자동 등록
# - 보안: 발급자 권한 전체를 가지므로 시연 한정, 절대 커밋 금지, 운영 반영 금지
# - 없으면 시드는 xnquiz DB 에만 퀴즈 생성하고 Canvas UI 동기화는 SKIP
CANVAS_API_TOKEN=

# Canvas 과목의 숫자 course_id (브라우저 URL /courses/<숫자>/ 의 숫자 부분)
# LTI 가 전달하는 context_id(40자 해시) 로는 Canvas REST API 가 404 를 반환하므로
# 시드용으로 숫자 id 를 별도 주입한다. 예: 32225
CANVAS_COURSE_ID=
