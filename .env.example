# .env.example — 팀 공유용 키 목록 (실제 값 없음)
# 복사 후 .env.local 로 저장하고 값 입력

# ─────────────────────────────────────────────
# Frontend (Vite)
# ─────────────────────────────────────────────
VITE_DATA_SOURCE=mock
VITE_APP_NAME=XN Quizzes

# Canvas OAuth (Canvas Admin > Developer Keys 에서 발급)
VITE_CANVAS_BASE_URL=
VITE_CANVAS_CLIENT_ID=
VITE_CANVAS_REDIRECT_URI=

# Canvas Client Secret — VITE_ 없이 등록 (서버사이드 전용)
CANVAS_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Backend (Vercel Serverless Functions)
# ─────────────────────────────────────────────

# Neon PostgreSQL — Neon 콘솔 > Connection Details 에서 복사
# 형식: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.aws.neon.tech/xnquiz?sslmode=require

# 마이그레이션용 직접 연결 URL (pooler 미경유)
# Neon 대시보드의 "direct connection" 값 사용
DIRECT_URL=postgresql://user:password@ep-xxxx.aws.neon.tech/xnquiz?sslmode=require

# JWT — 운영 환경에서는 `openssl rand -base64 32` 같은 방식으로 생성
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d
